
import React, { useEffect, useMemo, useState } from 'react'
import { createClient } from '@supabase/supabase-js'
import { createRoot } from 'react-dom/client'
import './styles.css'

const SUPABASE_URL = import.meta.env.VITE_SUPABASE_URL || ''
const SUPABASE_KEY = import.meta.env.VITE_SUPABASE_ANON_KEY || ''
const ADMIN_PASSWORD = import.meta.env.VITE_ADMIN_PASSWORD || 'CopaAkrk'

const supabaseReady = SUPABASE_URL.startsWith('https://') && SUPABASE_URL.includes('.supabase.co') && SUPABASE_KEY.length > 20
const supabase = supabaseReady ? createClient(SUPABASE_URL, SUPABASE_KEY) : null

const TEAMS = ['Praia de Itaipu','Praia do Flamengo','Praia do Arpoador','Praia de Ipanema','Praia do Forte','Operacional']

const PLAYERS = [
  'Nenhum',
  'Brasil - Alisson','Brasil - Ederson','Brasil - Gabriel Magalhães','Brasil - Marquinhos','Brasil - Casemiro','Brasil - Alex Sandro','Brasil - Vinícius Júnior','Brasil - Bruno Guimarães','Brasil - Matheus Cunha','Brasil - Neymar','Brasil - Raphinha','Brasil - Weverton','Brasil - Danilo','Brasil - Bremer','Brasil - Léo Pereira','Brasil - Douglas Santos','Brasil - Fabinho','Brasil - Danilo Santos','Brasil - Endrick','Brasil - Lucas Paquetá','Brasil - Luiz Henrique','Brasil - Gabriel Martinelli','Brasil - Ibañez','Brasil - Igor Thiago','Brasil - Rayan',
  'Japão - Zion Suzuki','Japão - Yuto Nagatomo','Japão - Shogo Taniguchi','Japão - Ko Itakura','Japão - Wataru Endo','Japão - Hidemasa Morita','Japão - Ao Tanaka','Japão - Takefusa Kubo','Japão - Ayase Ueda','Japão - Reo Hatate','Japão - Daizen Maeda','Japão - Keisuke Osako','Japão - Yukinari Sugawara','Japão - Junya Ito','Japão - Daichi Kamada','Japão - Koki Machida','Japão - Yuki Ohashi','Japão - Keito Nakamura','Japão - Kota Takai','Japão - Ayumu Seko','Japão - Hiroki Ito','Japão - Takehiro Tomiyasu','Japão - Tomoki Hayakawa','Japão - Ryotaro Araki','Japão - Junnosuke Suzuki','Japão - Shuto Machino'
]

function cleanCpf(value) {
  return String(value || '').replace(/\D/g, '')
}

function money(value) {
  return Number(value || 0).toLocaleString('pt-BR', { maximumFractionDigits: 2 })
}

function normalize(value) {
  return String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim()
}

function resultMultiplier(result) {
  if (result === 'Brasil') return 1.25
  if (result === 'Empate') return 2.5
  if (result === 'Japão') return 3.2
  return 1
}

function goalMultiplier(player) {
  return player === 'Nenhum' ? 4 : 3
}

function getRisk(bet) {
  const max =
    Number(bet.result_points || 0) * 1 * resultMultiplier(bet.result_pick) +
    Number(bet.score_points || 0) * 2 * 5 +
    Number(bet.player_points || 0) * 3 * goalMultiplier(bet.first_goal_player)

  const total = Number(bet.total_allocated || 0) || 1
  const volatility = max / total

  if (volatility >= 7) return { label: 'Alto', className: 'high', max, volatility }
  if (volatility >= 4) return { label: 'Médio', className: 'medium', max, volatility }
  return { label: 'Baixo', className: 'low', max, volatility }
}

function calculateScore(bet, official) {
  let score = 0
  let details = []

  if (bet.result_pick === official.result) {
    const pts = Number(bet.result_points || 0) * 1 * resultMultiplier(bet.result_pick)
    score += pts
    details.push(`resultado +${money(pts)}`)
  }

  if (Number(bet.brazil_score) === Number(official.brazil_score) && Number(bet.japan_score) === Number(official.japan_score)) {
    const pts = Number(bet.score_points || 0) * 2 * 5
    score += pts
    details.push(`placar +${money(pts)}`)
  }

  if (normalize(bet.first_goal_player) === normalize(official.first_goal_player)) {
    const pts = Number(bet.player_points || 0) * 3 * goalMultiplier(bet.first_goal_player)
    score += pts
    details.push(`1º gol +${money(pts)}`)
  }

  return { score, details: details.join(', ') || 'sem acerto' }
}

function avatar(name) {
  const initial = String(name || '?').trim().charAt(0).toUpperCase() || '?'
  return `data:image/svg+xml;utf8,${encodeURIComponent(`<svg xmlns="http://www.w3.org/2000/svg" width="90" height="90"><rect width="90" height="90" rx="45" fill="#10233d"/><text x="45" y="56" font-size="34" text-anchor="middle" fill="#f5c542">${initial}</text></svg>`)}`
}

async function fileToDataUrl(file) {
  if (!file) return ''
  return new Promise((resolve) => {
    const reader = new FileReader()
    reader.onload = () => resolve(reader.result)
    reader.readAsDataURL(file)
  })
}

function App() {
  const [role, setRole] = useState(localStorage.getItem('bcc_role') || '')
  const [cpf, setCpf] = useState(localStorage.getItem('bcc_cpf') || '')
  const [participants, setParticipants] = useState([])
  const [bets, setBets] = useState([])
  const [official, setOfficial] = useState({ result: 'Empate', brazil_score: 0, japan_score: 0, first_goal_player: 'Nenhum' })
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState('')

  async function loadData() {
    setLoading(true)
    setError('')

    try {
      if (!supabaseReady) {
        throw new Error('Supabase não configurado. Configure as variáveis VITE_SUPABASE_URL e VITE_SUPABASE_ANON_KEY na Vercel.')
      }

      const [p, b, r] = await Promise.all([
        supabase.from('participants').select('*').order('created_at', { ascending: false }),
        supabase.from('bets').select('*').order('created_at', { ascending: false }),
        supabase.from('game_result').select('*').eq('id', 1).maybeSingle()
      ])

      if (p.error) throw p.error
      if (b.error) throw b.error
      if (r.error) throw r.error

      setParticipants(p.data || [])
      setBets(b.data || [])
      if (r.data) setOfficial(r.data)
    } catch (e) {
      setError(e.message || String(e))
    }

    setLoading(false)
  }

  useEffect(() => {
    loadData()
  }, [])

  const ranking = useMemo(() => {
    return [...participants]
      .map((p) => {
        const bet = bets.find((b) => b.cpf === p.cpf)
        const points = bet ? 10 - Number(bet.total_allocated || 0) + calculateScore(bet, official).score : 10
        return { ...p, points }
      })
      .sort((a,b) => b.points - a.points)
      .slice(0,5)
  }, [participants, bets, official])

  function logout() {
    localStorage.removeItem('bcc_role')
    localStorage.removeItem('bcc_cpf')
    setRole('')
    setCpf('')
  }

  return (
    <main className="wrap">
      <section className="hero">
        <p className="tag">Credit RMA apresenta</p>
        <h1>🏆 Bolão da Copa Credit</h1>
        <p>Brasil x Japão • 10 pontos por CPF • Ranking Top 5</p>
      </section>

      {error ? <div className="notice err"><strong>Atenção:</strong><br />{error}</div> : <div className="notice ok">ONLINE: Supabase conectado.</div>}

      {loading ? <div className="card">Carregando dados...</div> : (
        <>
          {!role && <Home setRole={setRole} setCpf={setCpf} reload={loadData} />}
          {role === 'player' && <Player cpf={cpf} participants={participants} bets={bets} ranking={ranking} official={official} reload={loadData} logout={logout} />}
          {role === 'admin' && <Admin participants={participants} bets={bets} ranking={ranking} official={official} setOfficial={setOfficial} reload={loadData} logout={logout} />}
        </>
      )}
    </main>
  )
}

function Home({ setRole, setCpf, reload }) {
  const [form, setForm] = useState({ cpf: '', full_name: '', team_name: TEAMS[0], photo: null })
  const [password, setPassword] = useState('')

  async function enterPlayer() {
    const cleaned = cleanCpf(form.cpf)
    if (cleaned.length !== 11) return alert('CPF precisa ter 11 números.')
    if (form.full_name.trim().length < 3) return alert('Informe o nome completo.')

    const photo_url = await fileToDataUrl(form.photo)

    const existing = await supabase.from('participants').select('*').eq('cpf', cleaned).maybeSingle()
    if (existing.error) return alert(existing.error.message)

    if (existing.data) {
      const payload = { full_name: form.full_name.trim(), team_name: form.team_name }
      if (photo_url) payload.photo_url = photo_url
      const res = await supabase.from('participants').update(payload).eq('cpf', cleaned)
      if (res.error) return alert(res.error.message)
    } else {
      const res = await supabase.from('participants').insert({
        cpf: cleaned,
        full_name: form.full_name.trim(),
        team_name: form.team_name,
        photo_url
      })
      if (res.error) return alert(res.error.message)
    }

    localStorage.setItem('bcc_role', 'player')
    localStorage.setItem('bcc_cpf', cleaned)
    setRole('player')
    setCpf(cleaned)
    await reload()
  }

  function enterAdmin() {
    if (password !== ADMIN_PASSWORD) return alert('Senha inválida.')
    localStorage.setItem('bcc_role', 'admin')
    localStorage.removeItem('bcc_cpf')
    setRole('admin')
  }

  return (
    <section className="card">
      <h2>Entrar como apostador</h2>
      <label>CPF</label>
      <input value={form.cpf} onChange={(e) => setForm({ ...form, cpf: e.target.value })} inputMode="numeric" />
      <label>Nome completo</label>
      <input value={form.full_name} onChange={(e) => setForm({ ...form, full_name: e.target.value })} />
      <label>Equipe</label>
      <select value={form.team_name} onChange={(e) => setForm({ ...form, team_name: e.target.value })}>
        {TEAMS.map((t) => <option key={t}>{t}</option>)}
      </select>
      <label>Foto</label>
      <input type="file" accept="image/*" onChange={(e) => setForm({ ...form, photo: e.target.files[0] })} />
      <button onClick={enterPlayer}>Entrar no Bolão</button>

      <hr />

      <h2>Administrador</h2>
      <label>Senha Admin</label>
      <input type="password" value={password} onChange={(e) => setPassword(e.target.value)} />
      <button className="secondary" onClick={enterAdmin}>Acessar Admin</button>
    </section>
  )
}

function Player({ cpf, participants, bets, ranking, official, reload, logout }) {
  const participant = participants.find((p) => p.cpf === cpf)
  const myBet = bets.find((b) => b.cpf === cpf)
  const [bet, setBet] = useState({
    result_pick: 'Brasil',
    brazil_score: 2,
    japan_score: 0,
    first_goal_player: 'Brasil - Vinícius Júnior',
    result_points: 4,
    score_points: 3,
    player_points: 3
  })

  if (!participant) return <div className="card">Participante não encontrado. <button onClick={logout}>Voltar</button></div>

  const total = Number(bet.result_points || 0) + Number(bet.score_points || 0) + Number(bet.player_points || 0)
  const risk = getRisk({ ...bet, total_allocated: total })
  const bar = Math.min(100, total * 10)

  function setPoints(field, value) {
    let next = { ...bet, [field]: Number(value) || 0 }
    let nextTotal = Number(next.result_points || 0) + Number(next.score_points || 0) + Number(next.player_points || 0)
    if (nextTotal > 10) {
      next[field] = Math.max(0, Number(next[field]) - (nextTotal - 10))
    }
    setBet(next)
  }

  async function saveBet() {
    const finalTotal = Number(bet.result_points || 0) + Number(bet.score_points || 0) + Number(bet.player_points || 0)
    if (finalTotal !== 10) return alert('A aposta precisa fechar exatamente 10 pontos.')
    if (myBet) return alert('Este CPF já possui aposta.')

    const r = getRisk({ ...bet, total_allocated: finalTotal })
    const payload = {
      cpf,
      ...bet,
      total_allocated: finalTotal,
      max_possible: r.max,
      risk_label: r.label
    }

    const res = await supabase.from('bets').insert(payload)
    if (res.error) return alert(res.error.message)

    alert('Aposta confirmada.')
    await reload()
  }

  return (
    <div className="grid">
      <section className="card">
        <h2>Olá, {participant.full_name.split(' ')[0]}</h2>
        <div className="person">
          <img className="avatar" src={participant.photo_url || avatar(participant.full_name)} />
          <div>
            <strong>{participant.full_name}</strong><br />
            <small>{participant.team_name}</small>
          </div>
        </div>
        <button className="secondary" onClick={logout}>Sair</button>
      </section>

      <section className="card">
        <h2>⚽ Sua aposta</h2>
        <label>Resultado</label>
        <select value={bet.result_pick} onChange={(e) => setBet({ ...bet, result_pick: e.target.value })}>
          {['Brasil','Empate','Japão'].map((x) => <option key={x}>{x}</option>)}
        </select>

        <label>Pontos no resultado</label>
        <input type="number" value={bet.result_points} min="0" max="10" step="0.5" onChange={(e) => setPoints('result_points', e.target.value)} />

        <label>Placar exato</label>
        <div className="scorebox">
          <input type="number" value={bet.brazil_score} onChange={(e) => setBet({ ...bet, brazil_score: Number(e.target.value) })} />
          <span>x</span>
          <input type="number" value={bet.japan_score} onChange={(e) => setBet({ ...bet, japan_score: Number(e.target.value) })} />
        </div>

        <label>Pontos no placar</label>
        <input type="number" value={bet.score_points} min="0" max="10" step="0.5" onChange={(e) => setPoints('score_points', e.target.value)} />

        <label>Jogador do primeiro gol</label>
        <select value={bet.first_goal_player} onChange={(e) => setBet({ ...bet, first_goal_player: e.target.value })}>
          {PLAYERS.map((x) => <option key={x}>{x}</option>)}
        </select>

        <label>Pontos no primeiro gol</label>
        <input type="number" value={bet.player_points} min="0" max="10" step="0.5" onChange={(e) => setPoints('player_points', e.target.value)} />

        <div className="notice">
          <strong>Total alocado:</strong> {money(total)}/10
          <div className="meter"><div style={{ width: `${bar}%` }} /></div>
          <p className={`risk ${risk.className}`}>Risco da aposta: {risk.label}</p>
          <small>Potencial máximo se acertar tudo: {money(risk.max)} pontos. Quanto maior o potencial, maior o risco.</small>
        </div>

        <button disabled={Boolean(myBet)} onClick={saveBet}>{myBet ? 'Aposta já registrada' : 'Confirmar aposta'}</button>
      </section>

      <section className="card">
        <h2>📌 Regras</h2>
        <p>Resultado: peso 1</p>
        <p>Placar exato: peso 2</p>
        <p>Primeiro gol: peso 3</p>
        <p>A soma precisa fechar exatamente 10 pontos.</p>
      </section>

      <Ranking ranking={ranking} />

      <section className="card wide">
        <h2>Minha aposta</h2>
        {myBet ? (
          <div>
            <p><strong>{myBet.result_pick} • Brasil {myBet.brazil_score} x {myBet.japan_score} Japão</strong></p>
            <p>{myBet.first_goal_player}</p>
            <p>Total: {money(myBet.total_allocated)}/10 • Risco: {myBet.risk_label} • Potencial: {money(myBet.max_possible)}</p>
          </div>
        ) : <p>Nenhuma aposta registrada.</p>}
      </section>
    </div>
  )
}

function Ranking({ ranking }) {
  return (
    <section className="card wide">
      <h2>🏆 Ranking Top 5</h2>
      {ranking.length ? ranking.map((p, i) => (
        <div className="row" key={p.cpf}>
          <div className="person">
            <span>{['🥇','🥈','🥉','🏅','🏅'][i]}</span>
            <img className="avatar" src={p.photo_url || avatar(p.full_name)} />
            <div>
              <strong>{i + 1}. {p.full_name}</strong><br />
              <small>{p.team_name}</small>
            </div>
          </div>
          <div className="badge">{money(p.points)} pts</div>
        </div>
      )) : <p>Nenhum participante.</p>}
    </section>
  )
}

function Admin({ participants, bets, ranking, official, setOfficial, reload, logout }) {
  const [form, setForm] = useState(official)

  async function saveOfficial() {
    const payload = {
      id: 1,
      result: form.result,
      brazil_score: Number(form.brazil_score || 0),
      japan_score: Number(form.japan_score || 0),
      first_goal_player: form.first_goal_player,
      updated_at: new Date().toISOString()
    }
    const res = await supabase.from('game_result').upsert(payload)
    if (res.error) return alert(res.error.message)
    setOfficial(payload)
    alert('Resultado atualizado.')
    await reload()
  }

  async function releaseBet(cpf) {
    if (!confirm('Liberar nova aposta para este CPF?')) return
    const res = await supabase.from('bets').delete().eq('cpf', cpf)
    if (res.error) return alert(res.error.message)
    await reload()
  }

  async function deleteParticipant(cpf) {
    if (!confirm('Excluir participante e aposta vinculada?')) return
    const res = await supabase.from('participants').delete().eq('cpf', cpf)
    if (res.error) return alert(res.error.message)
    await reload()
  }

  function exportCsv() {
    const lines = [
      ['CPF','Nome','Equipe','Resultado','Placar Brasil','Placar Japão','Primeiro Gol','Pontos Resultado','Pontos Placar','Pontos Gol','Risco','Potencial'].join(';')
    ]
    participants.forEach((p) => {
      const b = bets.find((x) => x.cpf === p.cpf)
      lines.push([
        p.cpf,p.full_name,p.team_name,b?.result_pick || '',b?.brazil_score ?? '',b?.japan_score ?? '',b?.first_goal_player || '',b?.result_points ?? '',b?.score_points ?? '',b?.player_points ?? '',b?.risk_label || '',b?.max_possible ?? ''
      ].join(';'))
    })
    const blob = new Blob([lines.join('\\n')], { type: 'text/csv;charset=utf-8' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a')
    a.href = url
    a.download = 'bolao-copa-credit.csv'
    a.click()
    URL.revokeObjectURL(url)
  }

  return (
    <>
      <button className="secondary" onClick={logout}>Sair do Admin</button>
      <div className="grid">
        <section className="card">
          <h2>Resultado oficial</h2>
          <label>Resultado</label>
          <select value={form.result} onChange={(e) => setForm({ ...form, result: e.target.value })}>
            {['Brasil','Empate','Japão'].map((x) => <option key={x}>{x}</option>)}
          </select>

          <label>Placar</label>
          <div className="scorebox">
            <input type="number" value={form.brazil_score} onChange={(e) => setForm({ ...form, brazil_score: Number(e.target.value) })} />
            <span>x</span>
            <input type="number" value={form.japan_score} onChange={(e) => setForm({ ...form, japan_score: Number(e.target.value) })} />
          </div>

          <label>Primeiro gol</label>
          <select value={form.first_goal_player} onChange={(e) => setForm({ ...form, first_goal_player: e.target.value })}>
            {PLAYERS.map((x) => <option key={x}>{x}</option>)}
          </select>

          <button onClick={saveOfficial}>Atualizar ranking</button>
        </section>

        <section className="card">
          <h2>Controle</h2>
          <p>Participantes: <strong>{participants.length}</strong></p>
          <p>Apostas: <strong>{bets.length}</strong></p>
          <p>Sem aposta: <strong>{participants.length - bets.length}</strong></p>
          <button onClick={exportCsv}>Exportar CSV</button>
        </section>

        <section className="card">
          <h2>QR Code</h2>
          <img className="qr" src={`https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=${encodeURIComponent(location.href)}`} />
          <p className="small">{location.href}</p>
        </section>

        <Ranking ranking={ranking} />

        <section className="card wide">
          <h2>Cadastros e apostas</h2>
          {participants.length ? participants.map((p) => {
            const b = bets.find((x) => x.cpf === p.cpf)
            return (
              <div className="row" key={p.cpf}>
                <div className="person">
                  <img className="avatar" src={p.photo_url || avatar(p.full_name)} />
                  <div>
                    <strong>{p.full_name}</strong><br />
                    <small>{p.team_name} • CPF {p.cpf} • {b ? '✅ apostou' : '❌ sem aposta'}</small>
                    {b && <small><br />{b.result_pick} • Brasil {b.brazil_score} x {b.japan_score} Japão • {b.first_goal_player} • Risco {b.risk_label}</small>}
                  </div>
                </div>
                <div className="actions">
                  {b && <button className="green" onClick={() => releaseBet(p.cpf)}>Liberar nova aposta</button>}
                  <button className="danger" onClick={() => deleteParticipant(p.cpf)}>Excluir</button>
                </div>
              </div>
            )
          }) : <p>Nenhum cadastro.</p>}
        </section>
      </div>
    </>
  )
}

createRoot(document.getElementById('root')).render(<App />)
